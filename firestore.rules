rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read and write only their own profile document
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Creator call requests — anyone can submit, no one can read via client
    match /creator_calls/{id} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Expert applications — anyone can submit, no one can read via client
    match /expert_applications/{id} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}
